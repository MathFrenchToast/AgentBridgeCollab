# Agent Bridge Collaboration (ABC) Configuration Template

# Selection: discord, slack, teams
ABC_PROVIDER=discord

# Common Settings
ABC_PROVIDER_TOKEN=your_platform_token_here
AGENT_API_KEY=your_agent_api_key_here

# Optional: Comma-separated list of Discord User IDs allowed to use the bridge.
# If empty, all users can use it.
AUTHORIZED_USER_IDS=

# Discord Provider Specifics
# Required if ABC_PROVIDER=discord
DISCORD_GUILD_ID=your_discord_server_id
DISCORD_CATEGORY_ID=your_project_category_id
