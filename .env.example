# Gemini Collaboration Bridge (GCB) Configuration Template

# Selection: discord, slack, teams
GCB_PROVIDER=discord

# Common Settings
GCB_PROVIDER_TOKEN=your_platform_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Provider Specifics
# Required if GCB_PROVIDER=discord
DISCORD_GUILD_ID=your_discord_server_id
DISCORD_CATEGORY_ID=your_project_category_id
