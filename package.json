{
  "name": "gemini-collaboration-bridge",
  "version": "0.1.0",
  "description": "A bridge between Gemini CLI and collaboration platforms like Discord",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "pm2 start ecosystem.config.cjs",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "gemini",
    "discord",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "@slack/bolt": "^4.7.0",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.5",
    "pm2": "^5.3.1",
    "zod": "^3.22.4"
  }
}
